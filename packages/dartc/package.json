{
  "name": "@gemmapod/dartc",
  "version": "0.3.0",
  "type": "module",
  "description": "DARTC v0.2 — signed, topic-multiplexed envelope for portable AI agents. Carries A2A objects and AG-UI-shaped UI events over WebRTC and (future) WebSocket relays.",
  "keywords": [
    "dartc",
    "gemmapod",
    "ai-agents",
    "webrtc",
    "a2a",
    "ag-ui",
    "ed25519",
    "agent2agent"
  ],
  "license": "MIT",
  "author": "Raj Kushawaha <raj.design@gmail.com>",
  "homepage": "https://gemmapod.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apprider/gemmapod.git",
    "directory": "packages/dartc"
  },
  "bugs": {
    "url": "https://github.com/apprider/gemmapod/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "tsx --test src/*.test.ts",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
